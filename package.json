{
	"name": "@kylsgl/eslint-config",
	"version": "2.0.0",
	"description": "ESLint rules for JavaScript, TypeScript, and React, based on the Airbnb JavaScript Style Guide.",
	"keywords": [
		"eslint",
		"eslintconfig",
		"eslint-config"
	],
	"homepage": "https://github.com/kylsgl/eslint-config#readme",
	"bugs": {
		"url": "https://github.com/kylsgl/eslint-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kylsgl/eslint-config"
	},
	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/kylsgl"
		},
		{
			"type": "ko-fi",
			"url": "https://ko-fi.com/kylsgl"
		}
	],
	"license": "MIT",
	"author": {
		"name": "kylsgl",
		"email": "hello@kylsgl.com",
		"url": "https://github.com/kylsgl"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.ts"
		}
	},
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": [
		"./dist",
		"./CHANGELOG.md"
	],
	"scripts": {
		"build": "pnpm generate:rules && rolldown --config ./rolldown.config.ts",
		"build:eslint": "pnpm generate:rules && rolldown --config ./scripts/eslint-config/rolldown.config.ts",
		"format": "prettier --write .",
		"generate:rules": "tsx ./scripts/generate-rules.ts",
		"lint": "eslint ./",
		"lint:fix": "pnpm lint --fix",
		"lint:measure": "tsx ./scripts/eslint-measure.ts",
		"precommit": "pnpm lint:fix && pnpm format && pnpm test",
		"release": "pnpm build && changeset publish",
		"test": "tsc --noEmit && vitest --coverage"
	},
	"dependencies": {
		"@stylistic/eslint-plugin": "5.10.0",
		"@typescript-eslint/utils": "8.58.0",
		"@vitest/eslint-plugin": "1.6.14",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "4.4.4",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-n": "17.24.0",
		"eslint-plugin-package-json": "0.91.1",
		"eslint-plugin-perfectionist": "5.7.0",
		"eslint-plugin-promise": "7.2.1",
		"eslint-plugin-react-dom": "^4.2.1",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-jsx": "^4.2.1",
		"eslint-plugin-react-naming-convention": "^4.2.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"eslint-plugin-react-web-api": "^4.2.1",
		"eslint-plugin-react-x": "^4.2.1",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-simple-import-sort": "12.1.1",
		"eslint-plugin-sonarjs": "4.0.2",
		"eslint-plugin-testing-library": "7.16.2",
		"eslint-plugin-tsdoc": "0.5.2",
		"eslint-plugin-unicorn": "64.0.0",
		"globals": "17.4.0",
		"typescript-eslint": "8.58.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@kylsgl/changelog-github": "^1.0.0",
		"@types/estree": "^1.0.8",
		"@types/node": "^25.5.0",
		"@vitest/coverage-istanbul": "^4.1.2",
		"eslint": "^10.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"rolldown": "1.0.0-rc.13",
		"rolldown-plugin-dts": "^0.23.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">=22"
	}
}
